@model DemoMVCSQLite.Models.Ticket

@{
    ViewData["Title"] = "Modifier un billet";
}

<h1>✏️ Modifier un billet</h1>

<form asp-action="Edit">
    <input type="hidden" asp-for="TicketId" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="EventId" class="form-label">Soirée</label>
        <select asp-for="EventId" class="form-control" asp-items="ViewBag.Events"></select>
        <span asp-validation-for="EventId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Type" class="form-label"></label>
        <select asp-for="Type" class="form-control">
            <option value="Standard">Standard</option>
            <option value="VIP">VIP</option>
            <option value="VVIP">VVIP</option>
        </select>
        <span asp-validation-for="Type" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Prix" class="form-label"></label>
        <input asp-for="Prix" class="form-control" />
        <span asp-validation-for="Prix" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="NombreDispo" class="form-label"></label>
        <input asp-for="NombreDispo" class="form-control" />
        <span asp-validation-for="NombreDispo" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-warning">Modifier</button>
    <a asp-action="Index" class="btn btn-secondary">Annuler</a>
</form>