@{
    int pg = ViewBag.Page;
    int totalPages = ViewBag.TotalPages;
    int total = ViewBag.Total;
    string action = ViewContext.RouteData.Values["action"]?.ToString() ?? "Index";
    string controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var routeId = ViewContext.RouteData.Values["id"];
}

@if (totalPages > 1)
{
    <div class="d-flex justify-content-between align-items-center mt-3">
        <small class="text-muted">Total : @total élément(s) — Page @pg sur @totalPages</small>
        <nav>
            <ul class="pagination mb-0">
                <li class="page-item @(pg == 1 ? "disabled" : "")">
                    <a class="page-link" href="?pg=@(pg - 1)">Précédent</a>
                </li>

                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(pg == i ? "active" : "")">
                        <a class="page-link" href="?pg=@i">@i</a>
                    </li>
                }

                <li class="page-item @(pg == totalPages ? "disabled" : "")">
                    <a class="page-link" href="?pg=@(pg + 1)">Suivant</a>
                </li>
            </ul>
        </nav>
    </div>
}