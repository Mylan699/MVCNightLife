@model DemoMVCSQLite.Models.Artist

@{
    ViewData["Title"] = "Supprimer un artiste";
}

<h1>🗑️ Supprimer un artiste</h1>

<p class="text-danger">Êtes-vous sûr de vouloir supprimer <strong>@Model.Nom</strong> ?</p>

<dl class="row">
    <dt class="col-sm-3">Style</dt>
    <dd class="col-sm-9">@Model.Style</dd>
</dl>

<form asp-action="Delete">
    <input type="hidden" asp-for="ArtistId" />
    <button type="submit" class="btn btn-danger">Confirmer la suppression</button>
    <a asp-action="Index" class="btn btn-secondary">Annuler</a>
</form>