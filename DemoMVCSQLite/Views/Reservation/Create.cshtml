@model DemoMVCSQLite.Models.Reservation

@{
    ViewData["Title"] = "Ajouter une réservation";
}

<h1>📋 Ajouter une réservation</h1>

<form asp-action="Create">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="ClientId" class="form-label">Client</label>
        <select asp-for="ClientId" class="form-control" asp-items="ViewBag.Clients"></select>
        <span asp-validation-for="ClientId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="TicketId" class="form-label">Billet</label>
        <select asp-for="TicketId" class="form-control" asp-items="ViewBag.Tickets"></select>
        <span asp-validation-for="TicketId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="QteTickets" class="form-label">Quantité</label>
        <input asp-for="QteTickets" class="form-control" min="1" />
        <span asp-validation-for="QteTickets" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Statut" class="form-label"></label>
        <select asp-for="Statut" class="form-control" asp-items="Html.GetEnumSelectList<DemoMVCSQLite.Models.StatutReservation>()"></select>
    </div>

    <button type="submit" class="btn btn-primary">Enregistrer</button>
    <a asp-action="Index" class="btn btn-secondary">Annuler</a>
</form>