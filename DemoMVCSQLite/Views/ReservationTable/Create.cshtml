@model DemoMVCSQLite.Models.ReservationTable

@{
    ViewData["Title"] = "Ajouter une réservation table VIP";
}

<h1>🪑 Ajouter une réservation table VIP</h1>

<form asp-action="Create">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="ClientId" class="form-label">Client</label>
        <select asp-for="ClientId" class="form-control" asp-items="ViewBag.Clients"></select>
        <span asp-validation-for="ClientId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="TableVIPId" class="form-label">Table VIP</label>
        <select asp-for="TableVIPId" class="form-control" asp-items="ViewBag.Tables"></select>
        <span asp-validation-for="TableVIPId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="EventId" class="form-label">Soirée</label>
        <select asp-for="EventId" class="form-control" asp-items="ViewBag.Events"></select>
        <span asp-validation-for="EventId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Statut" class="form-label"></label>
        <select asp-for="Statut" class="form-control" asp-items="Html.GetEnumSelectList<DemoMVCSQLite.Models.StatutReservation>()"></select>
    </div>

    <button type="submit" class="btn btn-primary">Enregistrer</button>
    <a asp-action="Index" class="btn btn-secondary">Annuler</a>
</form>