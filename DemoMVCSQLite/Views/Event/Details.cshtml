@model DemoMVCSQLite.Models.Event

@{
    ViewData["Title"] = "Détails soirée";
}

<h1>🎉 @Model.Titre</h1>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<dl class="row">
    <dt class="col-sm-3">Date</dt>
    <dd class="col-sm-9">@Model.Date.ToString("dd/MM/yyyy HH:mm")</dd>

    <dt class="col-sm-3">Établissement</dt>
    <dd class="col-sm-9">@Model.Venue?.Nom</dd>

    <dt class="col-sm-3">Thème Musical</dt>
    <dd class="col-sm-9">@Model.ThemeMusical</dd>

    <dt class="col-sm-3">Prix Entrée</dt>
    <dd class="col-sm-9">@Model.PrixEntree €</dd>

    <dt class="col-sm-3">Capacité Max</dt>
    <dd class="col-sm-9">@Model.CapaciteMax personnes</dd>

    <dt class="col-sm-3">Statut</dt>
    <dd class="col-sm-9">@Model.Statut</dd>
</dl>

<h3>🎧 Artistes</h3>
@if (Model.EventArtists.Any())
{
    <ul>
        @foreach (var ea in Model.EventArtists)
        {
            <li>@ea.Artist.Nom — Passage à @ea.HeurePassage.ToString("HH:mm")</li>
        }
    </ul>
}
else
{
    <p>Aucun artiste programmé.</p>
}

<h3>🎟️ Billets disponibles</h3>
@if (Model.Tickets.Any())
{
    <table class="table table-sm">
        <thead>
            <tr>
                <th>Type</th>
                <th>Prix</th>
                <th>Disponibles</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var t in Model.Tickets)
            {
                <tr>
                    <td>@t.Type</td>
                    <td>@t.Prix €</td>
                    <td>@t.NombreDispo</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>Aucun billet disponible.</p>
}

<h3>👥 Clients inscrits (@ViewBag.TotalClients)</h3>
<a asp-action="ImportClients" asp-route-id="@Model.EventId" class="btn btn-success btn-sm mb-3">📥 Importer des clients (JSON)</a>

@{
    var reservationsPaged = ViewBag.ReservationsPaged as List<DemoMVCSQLite.Models.Reservation>;
}

@if (reservationsPaged != null && reservationsPaged.Any())
{
    <table class="table table-sm">
        <thead>
            <tr>
                <th>Nom</th>
                <th>Prénom</th>
                <th>Email</th>
                <th>Type billet</th>
                <th>Statut</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in reservationsPaged)
            {
                <tr>
                    <td>@r.Client.Nom</td>
                    <td>@r.Client.Prenom</td>
                    <td>@r.Client.Email</td>
                    <td>@r.Ticket.Type</td>
                    <td>@r.Statut</td>
                </tr>
            }
        </tbody>
    </table>

    <nav>
        <ul class="pagination">
            <li class="page-item @(ViewBag.Page == 1 ? "disabled" : "")">
                <a class="page-link" href="/Event/Details/@Model.EventId?pg=@(ViewBag.Page - 1)">Précédent</a>
            </li>

            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(ViewBag.Page == i ? "active" : "")">
                    <a class="page-link" href="/Event/Details/@Model.EventId?pg=@i">@i</a>
                </li>
            }

            <li class="page-item @(ViewBag.Page == ViewBag.TotalPages ? "disabled" : "")">
                <a class="page-link" href="/Event/Details/@Model.EventId?pg=@(ViewBag.Page + 1)">Suivant</a>
            </li>
        </ul>
    </nav>
}
else
{
    <p>Aucun client inscrit pour le moment.</p>
}

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.EventId" class="btn btn-warning">Modifier</a>
    <a asp-action="Index" class="btn btn-secondary">Retour</a>
</div>