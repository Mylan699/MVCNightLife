@model DemoMVCSQLite.Models.Event

@{
    ViewData["Title"] = "Importer des clients";
}

<h1>📥 Importer des clients — @Model.Titre</h1>
<p class="text-muted">@Model.Venue?.Nom — @Model.Date.ToString("dd/MM/yyyy HH:mm")</p>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="card mb-4">
    <div class="card-header">Format JSON attendu</div>
    <div class="card-body">
        <pre class="bg-light p-3 rounded">
[
  {
    "Nom": "Dupont",
    "Prenom": "Thomas",
    "Email": "thomas.dupont@gmail.com",
    "Telephone": "0612345678",
    "DateNaissance": "1998-05-15T00:00:00"
  },
  {
    "Nom": "Martin",
    "Prenom": "Lea",
    "Email": "lea.martin@gmail.com",
    "Telephone": "0698765432",
    "DateNaissance": "2000-09-22T00:00:00"
  }
]</pre>
    </div>
</div>

<form asp-action="ImportClients" asp-route-id="@Model.EventId" method="post">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label class="form-label">Coller votre JSON ici</label>
        <textarea name="jsonData" class="form-control" rows="10" placeholder="Coller votre JSON ici..."></textarea>
    </div>

    <button type="submit" class="btn btn-success">📥 Importer</button>
    <a asp-action="Details" asp-route-id="@Model.EventId" class="btn btn-secondary">Annuler</a>
</form>